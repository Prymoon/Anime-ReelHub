        }
        
        .logout-btn:hover {
            background-color: #ff3356;
        }
        
        .admin-actions {
            display: flex;
            justify-content: space-around;
            margin-bottom: 30px;
        }
        
        .admin-actions button {
            padding: 10px 20px;
